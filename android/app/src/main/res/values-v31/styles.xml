<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (API 31): splash sistem menampilkan logo Sekita (splash_logo)
     di atas latar biru brand, lalu langsung ke layar loading Flutter.
     splash_logo.png = 1152x1152, konten logo di tengah ~768x768 (sisanya
     transparan) supaya TIDAK ke-crop oleh mask lingkaran Android 12. -->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">#2563EB</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
