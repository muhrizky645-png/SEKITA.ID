<?xml version="1.0" encoding="utf-8"?>
<!-- Sama seperti values-v31 tapi utk mode gelap: ikon splash sistem transparan
     (tidak ada logo ke-crop), lalu langsung ke layar loading Flutter. -->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">#2563EB</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
