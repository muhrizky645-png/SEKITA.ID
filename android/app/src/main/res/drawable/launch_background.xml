<?xml version="1.0" encoding="utf-8"?>
<!-- Latar peluncuran = gradient brand (ungu -> biru), sama dgn layar loading
     Flutter (_SplashScreen). Tidak ada logo di sini supaya begitu app dibuka
     langsung mengalir mulus ke layar loading. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#7C3AED"
                android:endColor="#2563EB"
                android:angle="315"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>
